# Google AI Studio API Key
# IMPORTANT: Get key from https://aistudio.google.com/apikey (NOT Google Cloud Console)
# Free tier: 1500 req/day for gemini-1.5-flash, 50 req/day for gemini-2.0-flash
GEMINI_API_KEY=AIzaSy...

# Model (optional — default: gemini-flash-latest, auto-fallback: gemini-2.0-flash → gemini-1.5-flash → gemini-1.5-flash-8b)
# GEMINI_MODEL=gemini-flash-latest

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=meowtea_schema

# Server
PORT=3001
NODE_ENV=development

# Base URL of the beverage project's web server (for product images)
# e.g. Apache/XAMPP serving D:\Source\beverage-ordering-project\
BASE_IMAGE_URL=http://localhost:3001
